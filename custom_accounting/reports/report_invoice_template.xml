<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Invoice PDF Report Template -->
    <template id="report_invoice_document">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-call="web.external_layout">
                    <div class="page">
                        <!-- Header -->
                        <h2>
                            <span t-if="o.move_type == 'out_invoice'">Invoice</span>
                            <span t-if="o.move_type == 'out_refund'">Credit Note</span>
                            <span t-if="o.move_type == 'in_invoice'">Vendor Bill</span>
                            <span t-if="o.move_type == 'in_refund'">Vendor Credit Note</span>
                            <span t-esc="o.name"/>
                        </h2>

                        <!-- Invoice Info -->
                        <div class="row mt-4 mb-4">
                            <div class="col-6">
                                <strong>Customer:</strong><br/>
                                <span t-esc="o.partner_id.name"/><br/>
                                <span t-if="o.partner_id.street" t-esc="o.partner_id.street"/><br/>
                                <span t-if="o.partner_id.city" t-esc="o.partner_id.city"/>
                                <span t-if="o.partner_id.country_id" t-esc="o.partner_id.country_id.name"/>
                            </div>
                            <div class="col-6 text-end">
                                <strong>Invoice Date:</strong> <span t-esc="o.invoice_date"/><br/>
                                <strong>Due Date:</strong> <span t-esc="o.invoice_date_due"/><br/>
                                <strong t-if="o.invoice_origin">Source:</strong>
                                <span t-if="o.invoice_origin" t-esc="o.invoice_origin"/>
                            </div>
                        </div>

                        <!-- Invoice Lines -->
                        <table class="table table-sm table-bordered">
                            <thead>
                                <tr>
                                    <th>Description</th>
                                    <th class="text-end">Quantity</th>
                                    <th class="text-end">Unit Price</th>
                                    <th>Taxes</th>
                                    <th class="text-end">Amount</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="o.line_ids.filtered(lambda l: not l.is_tax_line and l.account_id.internal_group in ('income', 'expense'))" t-as="line">
                                    <tr>
                                        <td t-esc="line.name"/>
                                        <td class="text-end" t-esc="line.quantity"/>
                                        <td class="text-end" t-esc="'%.2f' % line.price_unit"/>
                                        <td>
                                            <t t-foreach="line.tax_ids" t-as="tax">
                                                <span class="badge bg-secondary" t-esc="tax.name"/>
                                            </t>
                                        </td>
                                        <td class="text-end" t-esc="'%.2f' % (line.debit or line.credit)"/>
                                    </tr>
                                </t>
                            </tbody>
                        </table>

                        <!-- Totals -->
                        <div class="row">
                            <div class="col-6"/>
                            <div class="col-6">
                                <table class="table table-sm">
                                    <tr>
                                        <td><strong>Subtotal</strong></td>
                                        <td class="text-end" t-esc="'%.2f' % o.amount_untaxed"/>
                                    </tr>
                                    <tr>
                                        <td>Taxes</td>
                                        <td class="text-end" t-esc="'%.2f' % o.amount_tax"/>
                                    </tr>
                                    <tr class="fw-bold border-top">
                                        <td>Total</td>
                                        <td class="text-end" t-esc="'%.2f' % o.amount_total"/>
                                    </tr>
                                    <tr t-if="o.amount_residual != o.amount_total">
                                        <td>Amount Due</td>
                                        <td class="text-end" t-esc="'%.2f' % o.amount_residual"/>
                                    </tr>
                                </table>
                            </div>
                        </div>

                        <!-- Terms -->
                        <div t-if="o.narration" class="mt-4">
                            <strong>Terms &amp; Conditions:</strong>
                            <p t-raw="o.narration"/>
                        </div>
                    </div>
                </t>
            </t>
        </t>
    </template>

    <record id="action_report_invoice" model="ir.actions.report">
        <field name="name">Invoice</field>
        <field name="model">account.move</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">custom_accounting.report_invoice_document</field>
        <field name="report_file">custom_accounting.report_invoice_document</field>
        <field name="print_report_name">'Invoice - %s' % object.name</field>
    </record>
</odoo>
