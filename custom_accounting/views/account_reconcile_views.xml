<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Reconciliation: List view of items to reconcile -->
    <record id="view_account_move_line_reconcile_tree" model="ir.ui.view">
        <field name="name">account.move.line.reconcile.tree</field>
        <field name="model">account.move.line</field>
        <field name="arch" type="xml">
            <tree string="Items to Reconcile">
                <field name="date"/>
                <field name="move_name"/>
                <field name="partner_id"/>
                <field name="account_id"/>
                <field name="name"/>
                <field name="debit"/>
                <field name="credit"/>
                <field name="amount_residual"/>
                <field name="reconciled"/>
                <field name="currency_id" column_invisible="1"/>
            </tree>
        </field>
    </record>

    <!-- Action: Unreconciled items -->
    <record id="action_account_unreconciled" model="ir.actions.act_window">
        <field name="name">Reconciliation</field>
        <field name="res_model">account.move.line</field>
        <field name="view_mode">list</field>
        <field name="view_id" ref="view_account_move_line_reconcile_tree"/>
        <field name="domain">[
            ('account_id.reconcile', '=', True),
            ('reconciled', '=', False),
            ('move_id.state', '=', 'posted')
        ]</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                All items are reconciled!
            </p>
        </field>
    </record>
</odoo>
