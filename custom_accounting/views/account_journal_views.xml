<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Journal: Tree View -->
    <record id="view_account_journal_tree" model="ir.ui.view">
        <field name="name">account.journal.tree</field>
        <field name="model">account.journal</field>
        <field name="arch" type="xml">
            <tree string="Journals">
                <field name="sequence" widget="handle"/>
                <field name="code"/>
                <field name="name"/>
                <field name="type"/>
                <field name="default_account_id"/>
                <field name="currency_id" groups="base.group_multi_currency"/>
            </tree>
        </field>
    </record>

    <!-- Journal: Form View -->
    <record id="view_account_journal_form" model="ir.ui.view">
        <field name="name">account.journal.form</field>
        <field name="model">account.journal</field>
        <field name="arch" type="xml">
            <form string="Journal">
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name" placeholder="e.g. Sales Journal"/></h1>
                    </div>
                    <group>
                        <group string="General">
                            <field name="code"/>
                            <field name="type"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                            <field name="currency_id" groups="base.group_multi_currency"/>
                        </group>
                        <group string="Accounts">
                            <field name="default_account_id"/>
                            <field name="payment_debit_account_id"
                                invisible="type not in ('bank', 'cash')"/>
                            <field name="payment_credit_account_id"
                                invisible="type not in ('bank', 'cash')"/>
                            <field name="suspense_account_id"
                                invisible="type not in ('bank', 'cash')"/>
                        </group>
                    </group>
                    <group>
                        <group string="Advanced Settings">
                            <field name="lock_date"/>
                            <field name="sequence_id"/>
                        </group>
                    </group>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- Action -->
    <record id="action_account_journal" model="ir.actions.act_window">
        <field name="name">Journals</field>
        <field name="res_model">account.journal</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a new journal
            </p>
        </field>
    </record>
</odoo>
