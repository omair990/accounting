<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- App-launcher kanban: every top-level menu becomes a tile.
         Visual style matches the Odoo Enterprise home page. -->
    <record id="view_omran_launcher_kanban" model="ir.ui.view">
        <field name="name">omran.launcher.kanban</field>
        <field name="model">ir.ui.menu</field>
        <field name="arch" type="xml">
            <kanban create="false" edit="false" delete="false"
                    class="o_omran_launcher" group_create="false">
                <field name="id"/>
                <field name="name"/>
                <field name="web_icon_data"/>
                <field name="action"/>
                <templates>
                    <t t-name="kanban-box">
                        <button type="object" name="omran_open" class="o_omran_app">
                            <div class="o_omran_app_icon">
                                <img t-if="record.web_icon_data.raw_value"
                                     t-att-src="'data:image/png;base64,' + record.web_icon_data.raw_value"
                                     alt="Icon"/>
                            </div>
                            <div class="o_omran_app_name">
                                <t t-esc="record.name.raw_value"/>
                            </div>
                        </button>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- Update the home server action in place (same xmlid as before so
         every user.action_id pointer still resolves). It now redirects to
         the launcher window action. -->
    <record id="action_omran_dashboard" model="ir.actions.server">
        <field name="name">OCIT Home</field>
        <field name="model_id" ref="base.model_ir_ui_menu"/>
        <field name="state">code</field>
        <field name="code">action = env.ref('omran_dashboard.action_omran_launcher').sudo().read()[0]</field>
    </record>

    <!-- Window action for the launcher. Excludes our own Home menu (whose
         action is action_omran_dashboard) to prevent a self-loop tile. -->
    <record id="action_omran_launcher" model="ir.actions.act_window">
        <field name="name">Home</field>
        <field name="res_model">ir.ui.menu</field>
        <field name="view_mode">kanban</field>
        <field name="view_id" ref="view_omran_launcher_kanban"/>
        <field name="domain"
               eval="[('parent_id', '=', False), ('action', '!=', False),
                      ('action', '!=', 'ir.actions.server,%d' % ref('action_omran_dashboard'))]"/>
        <field name="target">main</field>
    </record>

    <menuitem id="menu_omran_dashboard_root"
              name="Home"
              sequence="0"
              action="action_omran_dashboard"
              web_icon="omran_dashboard,static/description/icon.png"/>
</odoo>
