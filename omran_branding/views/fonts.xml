<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="omran_fonts" inherit_id="web.layout" name="Omran IT web fonts">
        <xpath expr="//head" position="inside">
            <link rel="preconnect" href="https://fonts.googleapis.com"/>
            <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="anonymous"/>
            <link rel="stylesheet"
                  href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&amp;family=Tajawal:wght@400;500;700&amp;display=swap"/>
        </xpath>
    </template>
</odoo>
