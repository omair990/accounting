<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Replace the default logo block at the top of the login card -->
    <template id="login_layout_branding" inherit_id="web.login_layout" name="Omran IT login layout">
        <xpath expr="//img[@alt='Logo']" position="replace">
            <div class="omran_login_header text-center">
                <h1 class="omran_brand">Omran IT</h1>
                <p class="omran_tagline">Enterprise Resource Planning</p>
            </div>
        </xpath>
        <xpath expr="//a[contains(@href, 'odoo.com')]" position="replace">
            <span class="text-muted">© Omran IT · Secure ERP access</span>
        </xpath>
    </template>
</odoo>
