<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Login page branding. We avoid selecting on the logo via @alt because
         Odoo 17 forbids translatable attributes as inheritance selectors.
         The actual logo image is replaced by the company logo upload in
         data/company_data.xml — no XPath needed. We only customize the
         footer link here. -->
    <template id="login_layout_branding" inherit_id="web.login_layout" name="Omran IT login layout">
        <xpath expr="//a[contains(@href, 'odoo.com')]" position="replace">
            <span class="text-muted">© Omran IT · Secure ERP access</span>
        </xpath>
    </template>
</odoo>
